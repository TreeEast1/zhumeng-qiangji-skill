{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SchoolRecommenderOutput",
  "type": "object",
  "required": ["question_type", "recommendation_band", "candidate_schools"],
  "additionalProperties": false,
  "properties": {
    "question_type": {"const": "school_recommendation"},
    "recommendation_band": {"type": "string"},
    "candidate_schools": {"type": "array", "items": {"type": "string"}},
    "rationale": {"type": "array", "items": {"type": "string"}},
    "risk_level": {"type": "string"}
  }
}

